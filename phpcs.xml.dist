<?xml version="1.0"?>
<ruleset name="Scolta Drupal">
  <description>Drupal coding standards for Scolta module</description>
  <arg name="extensions" value="php,module,install,inc,theme"/>
  <arg name="colors"/>
  <arg value="sp"/>

  <file>src</file>

  <rule ref="Drupal"/>
  <rule ref="DrupalPractice"/>

  <!-- Allow long lines in tests -->
  <rule ref="Drupal.Files.LineLength">
    <exclude-pattern>tests/*</exclude-pattern>
  </rule>
</ruleset>
