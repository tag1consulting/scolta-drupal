{
    "name": "tag1/scolta-drupal",
    "description": "Scolta AI Search for Drupal — Search API backend with Pagefind client-side search",
    "type": "drupal-module",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Tag1 Consulting",
            "homepage": "https://www.tag1.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "tag1/scolta-php": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "symfony/yaml": "^6.0|^7.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../scolta-php"
        }
    ],
    "autoload": {
        "psr-4": {
            "Drupal\\scolta\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Drupal\\scolta\\Tests\\": "tests/src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
